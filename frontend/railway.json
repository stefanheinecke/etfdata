{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile",
    "dockerContextDir": "."
  },
  "deploy": {
    "startCommand": "/app/start.sh",
    "healthcheckUrl": "/",
    "healthcheckInterval": 10,
    "restartPolicyMaxRetries": 5
  }
}
